{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "output/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "terms.html",
      "use": "@vercel/static"
    },
    {
      "src": "privacy.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api(?:/(.*))?$",
      "dest": "/api/[...path].js"
    },
    {
      "src": "^/output(?:/(.*))?$",
      "dest": "/output/[...path].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/terms/?$",
      "dest": "/terms.html"
    },
    {
      "src": "^/privacy/?$",
      "dest": "/privacy.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
