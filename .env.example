# Clip Studio ES - NAS / local deployment
#
# Copy to `.env` on the NAS and adjust values.

PYTHONUNBUFFERED=1
CLIP_ANALYSIS_MAX_SECONDS=150

# Frontend origins allowed to call this backend.
CORS_ORIGINS=https://tiktok-xi-cyan.vercel.app,http://127.0.0.1:8780,http://192.168.68.65:8780

# Optional public base URL. Relative asset URLs are preferred, so this can stay empty.
BACKEND_PUBLIC_URL=

# Persistent storage
OUTPUT_DIR=/home/SrSainz/apps/tiktok/output
WORK_DIR=/home/SrSainz/apps/tiktok/work
YTDLP_COOKIES_FILE=/home/SrSainz/apps/tiktok/data/cookies.txt

# YouTube discovery
YOUTUBE_API_KEY=
YOUTUBE_TREND_CATEGORY_IDS=20,24

# Telegram delivery (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_APPROVALS_ENABLED=1

# Daily review scheduler
DAILY_REVIEW_SCHEDULER_ENABLED=1
DAILY_REVIEW_SLOT_TIMES=09:30,13:30,18:30,21:30,23:00
DAILY_REVIEW_PREP_MINUTES=20

# TikTok Direct Post (optional)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://127.0.0.1:8765/callback/
TIKTOK_TOKENS_FILE=/home/SrSainz/apps/tiktok/.tiktok_tokens.json
TIKTOK_DEFAULT_PRIVACY=PUBLIC_TO_EVERYONE
TIKTOK_EXPECTED_USERNAME=pixelboom8

# Browser automation fallback when Direct Post is rejected by TikTok guidelines.
# Typical setup: run Brave/Chrome on a Windows PC with remote debugging enabled and let the NAS connect over CDP.
TIKTOK_BROWSER_FALLBACK_ENABLED=0
TIKTOK_BROWSER_CONNECT_CDP=
TIKTOK_BROWSER_CHANNEL=brave
TIKTOK_BROWSER_EXECUTABLE=
TIKTOK_BROWSER_PROFILE_DIR=/home/SrSainz/apps/tiktok/.tiktok_profile
TIKTOK_BROWSER_MANUAL_WAIT=45
TIKTOK_BROWSER_AUTO_POST=1
TIKTOK_BROWSER_USE_SYSTEM_PROFILE=1
TIKTOK_BROWSER_USER_DATA_DIR=
TIKTOK_BROWSER_PROFILE_DIRECTORY=Default
TIKTOK_BROWSER_TIMEOUT_SEC=900
